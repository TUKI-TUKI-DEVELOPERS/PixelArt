# ══════════════════════════════════════════════════════════════════════════════
# MODO HÍBRIDO (default recomendado en desarrollo)
#   - postgres, redis y minio corren en Docker
#   - La API (NestJS) y el Web (Next.js) corren en local con `npm run dev`
#   - Los hosts apuntan a localhost porque los contenedores exponen sus puertos
#
# MODO FULL-DOCKER
#   - Todos los servicios corren en Docker
#   - Los hosts deben ser los nombres de servicio de Docker Compose
#   - Cambia: POSTGRES_HOST=postgres | REDIS_HOST=redis | MINIO_ENDPOINT=minio
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost          # full-docker: postgres
POSTGRES_PORT=5432
POSTGRES_DB=pixelart
POSTGRES_USER=pixelart
POSTGRES_PASSWORD=pixelart_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost             # full-docker: redis
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── MinIO (S3-compatible) ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost         # full-docker: minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=pixelart_access
MINIO_SECRET_KEY=pixelart_secret_key
MINIO_BUCKET=pixelart-assets

# ─── NestJS API ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ─── Next.js Web ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Email (placeholder) ──────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
EMAIL_FROM=noreply@pixelart.local

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d
